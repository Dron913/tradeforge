# Railway API URL (your TradeForge deployment)
# Get this from: railway status
VITE_RAILWAY_API_URL=https://tradeforge-production-fbc1.up.railway.app

# Auth mode: set DASHBOARD_PASSWORD in Railway env vars to enable auth
# The dashboard will show a login screen when auth is enabled.
# Without DASHBOARD_PASSWORD set on Railway, the dashboard is public.

# Optional local dev auth override
VITE_BYPASS_AUTH=false

# Polling interval in ms (default: 30000 = 30 seconds)
VITE_POLL_INTERVAL=30000